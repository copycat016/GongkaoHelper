SERVER_PORT=21080
GIN_MODE=debug

# GIN_MODE=release 时必须设置 JWT_SECRET。
# 开发模式可留空，后端会生成临时密钥；重启后旧 token 会失效。
JWT_SECRET=
JWT_EXPIRE_HOURS=168
AUTH_MODE=single

# 空库首次启动会创建单人管理员。
# release 模式必须设置强密码；debug 模式留空时使用开发默认密码 123456。
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=
AUTH_BOOTSTRAP_DISPLAY_NAME=Owner

# sqlite 或 postgres/postgresql。默认推荐 sqlite，本地无需启动数据库服务。
DB_DRIVER=sqlite
SQLITE_PATH=./data/gkweb.db

DB_HOST=localhost
DB_PORT=21432
DB_USER=gkweb
DB_PASSWORD=gkweb_password
DB_NAME=gkweb
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

POSTGRES_PORT=21432
POSTGRES_USER=gkweb
POSTGRES_PASSWORD=gkweb_password
POSTGRES_DB=gkweb

BAIDU_OCR_ENABLED=false
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_MONTHLY_LIMIT=200
BAIDU_OCR_TIMEOUT_SECONDS=30
