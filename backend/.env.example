SERVER_PORT=21080
GIN_MODE=debug

# sqlite 或 postgres/postgresql。默认推荐 sqlite，本地无需启动数据库服务。
DB_DRIVER=sqlite
SQLITE_PATH=./data/gkweb.db

DB_HOST=localhost
DB_PORT=21432
DB_USER=gkweb
DB_PASSWORD=gkweb_password
DB_NAME=gkweb
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

POSTGRES_PORT=21432
POSTGRES_USER=gkweb
POSTGRES_PASSWORD=gkweb_password
POSTGRES_DB=gkweb

BAIDU_OCR_ENABLED=false
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_MONTHLY_LIMIT=200
BAIDU_OCR_TIMEOUT_SECONDS=30
